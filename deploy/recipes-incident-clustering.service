[Unit]
Description=Recipes auto-improve — hourly incident clustering
After=network.target postgresql.service

[Service]
Type=oneshot
User=wisechef
WorkingDirectory=/srv/recipes-api
EnvironmentFile=/etc/recipes-api/wiserecipes-api.env
ExecStart=/srv/recipes-api/.venv/bin/python -m app.crons.incident_clustering
StandardOutput=journal
StandardError=journal
