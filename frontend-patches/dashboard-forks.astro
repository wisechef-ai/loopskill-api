---
// D.4 — Operator-tier forks dashboard
// Target: /home/adam/repos/recipes-portal/src/pages/dashboard/forks.astro
//
// Lists the signed-in user's forks, lets them edit the readme, toggle
// visibility, and view version history. Authentication relies on the
// portal's existing session cookie -> JWT bridge; the backend API key is
// fetched via /api/api-keys and stored in localStorage by the dashboard
// shell. If you don't have that bridge, prompt for the key on first load.
//
// All API calls hit POST/GET/DELETE under /api/forks/* with `x-api-key`.
// Cook-tier users land here with a 402 — render the upgrade banner.
//
// v1 deliberately uses a textarea instead of a WYSIWYG markdown editor.
// The "Save" button POSTs a fresh version; visibility toggle PATCHes.
// (Backend currently exposes upload-version + delete; a future PR adds
// PATCH /api/forks/<id> for visibility/readme updates without bumping
// a version.)

import Layout from "../../layouts/Layout.astro";

const API_BASE = import.meta.env.PUBLIC_RECIPES_API_BASE || "https://recipes.wisechef.ai";
---

<Layout title="Your forks — Recipes">
  <main class="forks-dashboard">
    <header>
      <h1>Your forks</h1>
      <p class="muted">Operator and Studio tiers. Fork any public skill, edit it, and install it on any of your agents.</p>
    </header>

    <section id="upgrade-banner" hidden>
      <strong>Operator tier required.</strong>
      <a href="/pricing#operator">Upgrade →</a>
    </section>

    <section id="forks-empty" hidden>
      <p>You don't have any forks yet. Run <code>recipes fork &lt;slug&gt;</code> to create one.</p>
    </section>

    <ul id="fork-list"></ul>

    <template id="fork-row-template">
      <li class="fork-row">
        <header>
          <h2 class="fork-name"></h2>
          <span class="fork-slug muted"></span>
        </header>

        <p class="fork-source muted">
          Forked from <a class="fork-source-slug"></a>
        </p>

        <label>
          README
          <textarea class="fork-readme" rows="6" placeholder="# Notes for this fork"></textarea>
        </label>

        <label>
          Visibility
          <select class="fork-visibility">
            <option value="private">private</option>
            <option value="team">team (Studio)</option>
            <option value="public">public</option>
          </select>
        </label>

        <details>
          <summary>Version history</summary>
          <ol class="fork-versions"></ol>
        </details>

        <div class="fork-actions">
          <button class="save-btn">Save</button>
          <button class="install-btn">Install URL</button>
          <button class="delete-btn danger">Delete</button>
        </div>
      </li>
    </template>
  </main>
</Layout>

<script define:vars={{ API_BASE }}>
  const apiKey = localStorage.getItem("recipes_api_key");
  if (!apiKey) {
    location.href = "/dashboard?reason=no_api_key";
  }

  async function api(path, init = {}) {
    const res = await fetch(`${API_BASE}${path}`, {
      ...init,
      headers: {
        "x-api-key": apiKey,
        "content-type": "application/json",
        ...(init.headers || {}),
      },
    });
    return res;
  }

  async function loadForks() {
    const res = await api("/api/forks/list");
    if (res.status === 402) {
      document.getElementById("upgrade-banner").hidden = false;
      return;
    }
    const { forks } = await res.json();
    const ul = document.getElementById("fork-list");
    if (!forks.length) {
      document.getElementById("forks-empty").hidden = false;
      return;
    }
    const tpl = document.getElementById("fork-row-template");
    forks.forEach((fork) => {
      const node = tpl.content.cloneNode(true);
      node.querySelector(".fork-name").textContent = fork.name;
      node.querySelector(".fork-slug").textContent = fork.slug;
      const srcLink = node.querySelector(".fork-source-slug");
      srcLink.textContent = fork.source_slug || "(source)";
      if (fork.source_slug) srcLink.href = `/skills/${fork.source_slug}`;
      node.querySelector(".fork-readme").value = fork.readme || "";
      node.querySelector(".fork-visibility").value = fork.visibility || "private";
      const versions = node.querySelector(".fork-versions");
      (fork.versions || []).forEach((v) => {
        const li = document.createElement("li");
        li.textContent = `${v.semver} — ${(v.tarball_size_bytes / 1024).toFixed(1)} KB — ${v.checksum_sha256.slice(0, 12)}…`;
        versions.appendChild(li);
      });

      node.querySelector(".save-btn").addEventListener("click", async () => {
        // v1: emit a console hint until PATCH endpoint lands
        console.info("save: TODO PATCH /api/forks/" + fork.id, {
          readme: node.querySelector(".fork-readme").value,
          visibility: node.querySelector(".fork-visibility").value,
        });
        alert("Save: PATCH endpoint ships next batch (D.4 v2). Use `recipes publish-fork` for now.");
      });

      node.querySelector(".install-btn").addEventListener("click", async () => {
        const r = await api(`/api/forks/${fork.id}/install`);
        if (!r.ok) {
          alert("Install URL failed: " + r.status);
          return;
        }
        const data = await r.json();
        await navigator.clipboard.writeText(data.tarball_url);
        alert(`Signed install URL copied. Expires ${new Date(data.expires_at).toLocaleTimeString()}.`);
      });

      node.querySelector(".delete-btn").addEventListener("click", async () => {
        if (!confirm(`Delete fork "${fork.name}"? Soft-delete; version history retained.`)) return;
        const r = await api(`/api/forks/${fork.id}`, { method: "DELETE" });
        if (r.ok) location.reload();
      });

      ul.appendChild(node);
    });
  }

  loadForks().catch((err) => {
    console.error(err);
    alert("Failed to load forks. Check console.");
  });
</script>

<style>
  .forks-dashboard { max-width: 760px; margin: 2rem auto; padding: 0 1rem; }
  .muted { color: #666; font-size: 0.9em; }
  .fork-row { border: 1px solid #e0e0e0; border-radius: 6px; padding: 1rem; margin-bottom: 1rem; }
  .fork-row textarea { width: 100%; font-family: monospace; }
  .fork-actions { display: flex; gap: 0.5rem; margin-top: 0.75rem; }
  .danger { background: #b00020; color: white; }
  #upgrade-banner { background: #fff5e1; border: 1px solid #f0ad4e; padding: 0.75rem; border-radius: 6px; margin-bottom: 1rem; }
</style>
