---
// frontend-patches/dashboard-buckets.astro
//
// Phase E.5 (v5.4) — Studio dashboard for buckets.
//
// Drop this file at `src/pages/dashboard/buckets.astro` in the
// recipes-portal Astro repo (the portal-worker integration applies this
// patch on its own deploy cadence). Same pattern as Phase D.4
// dashboard-forks.astro.
//
// Renders three panels:
//   1. Bucket builder — list current buckets, create new ones, add skills
//      to a selected bucket via slug. Drag-and-drop is deferred — v1 ships
//      a simple form.
//   2. Apply panel — kicks off POST /api/buckets/{id}/apply, then polls
//      GET /api/buckets/{id}/jobs/{job_id} every 2s until status is no
//      longer `applying`.
//   3. Audit log — install_events scoped to this bucket (server-rendered).

import Layout from "../../layouts/Dashboard.astro";

const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "https://api.recipes.wisechef.ai";

// Server-side pre-fetch of buckets list for first paint. Token comes from
// the wr_jwt cookie which the portal forwards via `request.headers`.
let buckets = [];
let tier = null;
try {
  const res = await fetch(`${apiBase}/api/buckets/list`, {
    headers: { cookie: Astro.request.headers.get("cookie") || "" },
  });
  if (res.ok) {
    const body = await res.json();
    buckets = body.buckets || [];
  } else if (res.status === 402) {
    tier = "insufficient";
  } else if (res.status === 401) {
    return Astro.redirect("/signin?next=/dashboard/buckets");
  }
} catch (e) {
  console.error("buckets fetch failed", e);
}
---

<Layout title="Buckets — Recipes Studio">
  {tier === "insufficient" ? (
    <section class="upsell">
      <h1>Buckets are a Studio feature</h1>
      <p>
        Bundle your skills, forks, services, and crons into a single
        atomic install. Apply to any agent in seconds.
      </p>
      <a class="btn-primary" href="/billing/upgrade?to=studio">
        Upgrade to Studio
      </a>
    </section>
  ) : (
    <section class="bucket-builder">
      <header>
        <h1>Buckets</h1>
        <button id="new-bucket-btn" class="btn-primary">New bucket</button>
      </header>

      <ul class="bucket-list">
        {buckets.map((b) => (
          <li data-id={b.id} data-slug={b.slug}>
            <strong>{b.name}</strong>
            <span class="slug">/{b.slug}</span>
            <span class={`pill pill-${b.visibility}`}>{b.visibility}</span>
            {b.is_white_label && <span class="pill pill-wl">white-label</span>}
            <div class="actions">
              <button class="btn-add-skill">+ skill</button>
              <button class="btn-apply">Apply…</button>
            </div>
          </li>
        ))}
      </ul>

      <section class="apply-panel" id="apply-panel" hidden>
        <h2>Applying <span id="apply-bucket-name"></span></h2>
        <progress id="apply-progress" value="0" max="100"></progress>
        <pre id="apply-log" aria-live="polite"></pre>
      </section>

      <section class="audit-panel">
        <h2>Audit log</h2>
        <p class="dim">Who applied what, when. Scoped to your buckets.</p>
        <table id="audit-table">
          <thead>
            <tr><th>When</th><th>Bucket</th><th>Skill</th><th>Version</th></tr>
          </thead>
          <tbody></tbody>
        </table>
      </section>
    </section>
  )}
</Layout>

<script define:vars={{ apiBase }}>
  // ── New-bucket flow ────────────────────────────────────────────────────
  document.getElementById("new-bucket-btn")?.addEventListener("click", async () => {
    const name = prompt("Bucket name?");
    if (!name) return;
    const description = prompt("Description (optional)") || null;
    const res = await fetch(`${apiBase}/api/buckets/create`, {
      method: "POST",
      credentials: "include",
      headers: { "content-type": "application/json" },
      body: JSON.stringify({ name, description, visibility: "private", pin_mode: "latest-stable" }),
    });
    if (res.ok) {
      window.location.reload();
    } else {
      const err = await res.json().catch(() => ({}));
      alert(`Create failed: ${err.detail || res.status}`);
    }
  });

  // ── Add-skill-by-slug flow (v1 — drag-and-drop deferred) ──────────────
  document.querySelectorAll(".btn-add-skill").forEach((btn) => {
    btn.addEventListener("click", async (ev) => {
      const li = ev.target.closest("li");
      const bucketId = li.dataset.id;
      const skillSlug = prompt("Skill slug to add?");
      if (!skillSlug) return;
      // Look up the skill id by slug, then add.
      const lookup = await fetch(`${apiBase}/api/skills/${skillSlug}`);
      if (!lookup.ok) { alert(`Unknown skill: ${skillSlug}`); return; }
      const skill = await lookup.json();
      const versionPin = prompt("Version pin? (blank = latest)") || null;
      const res = await fetch(`${apiBase}/api/buckets/${bucketId}/skills/add`, {
        method: "POST",
        credentials: "include",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ skill_id: skill.id, version_pin: versionPin }),
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        alert(`Add failed: ${err.detail || res.status}`);
      }
    });
  });

  // ── Apply + poll flow ──────────────────────────────────────────────────
  document.querySelectorAll(".btn-apply").forEach((btn) => {
    btn.addEventListener("click", async (ev) => {
      const li = ev.target.closest("li");
      const bucketId = li.dataset.id;
      const bucketName = li.querySelector("strong")?.textContent || "";

      const panel = document.getElementById("apply-panel");
      panel.hidden = false;
      document.getElementById("apply-bucket-name").textContent = bucketName;
      const log = document.getElementById("apply-log");
      log.textContent = "Kicking off apply…\n";

      const res = await fetch(`${apiBase}/api/buckets/${bucketId}/apply`, {
        method: "POST", credentials: "include",
      });
      if (!res.ok) { log.textContent += `Apply failed (${res.status})\n`; return; }
      const { job_id, skills } = await res.json();
      log.textContent += `Job ${job_id} — ${skills} skills queued\n`;

      let done = false;
      while (!done) {
        await new Promise((r) => setTimeout(r, 2000));
        const sres = await fetch(`${apiBase}/api/buckets/${bucketId}/jobs/${job_id}`, {
          credentials: "include",
        });
        if (!sres.ok) { log.textContent += `poll error ${sres.status}\n`; break; }
        const status = await sres.json();
        log.textContent += `[${new Date().toLocaleTimeString()}] ${status.status}\n`;
        if (status.status !== "applying") done = true;
      }
    });
  });
</script>

<style>
  .pill { padding: 2px 8px; border-radius: 12px; font-size: 0.8em; margin-left: 8px; }
  .pill-private { background: #eee; }
  .pill-team { background: #cdf; }
  .pill-public { background: #cfc; }
  .pill-wl { background: #fc9; }
  .upsell { padding: 4em 2em; text-align: center; }
  .apply-panel pre { background: #111; color: #0f0; padding: 1em; max-height: 240px; overflow: auto; }
  .audit-panel { margin-top: 2em; }
</style>
